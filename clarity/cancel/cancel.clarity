module HitlCancel

import { positional, flag_or } from "std/cli"

function opt_str(value: Option<String>, fallback: String) -> String {
  match value {
    Some(v) -> v,
    None -> fallback
  }
}

function normalize_dir(raw: String) -> String {
  let trimmed = trim(raw);
  match string_length(trimmed) == 0 {
    True -> ".clarity-hitl",
    False -> trimmed
  }
}

function path_join(dir: String, file: String) -> String {
  match string_ends_with(dir, "/") {
    True -> dir ++ file,
    False -> dir ++ "/" ++ file
  }
}

function char_is_safe(ch: String) -> Bool {
  contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789._-", ch)
}

function sanitize_key(raw: String, idx: Int64, acc: String) -> String {
  match idx >= string_length(raw) {
    True -> acc,
    False -> {
      let ch = char_at(raw, idx);
      let next = match char_is_safe(ch) {
        True -> acc ++ ch,
        False -> acc ++ "_"
      };
      sanitize_key(raw, idx + 1, next)
    }
  }
}

function to_safe_key(key: String) -> String {
  let cleaned = sanitize_key(trim(key), 0, "");
  match string_length(cleaned) > 0 {
    True -> cleaned,
    False -> "question"
  }
}

effect[FileSystem, Secret] function resolve_dir(args: List<String>) -> String {
  let positional_dir = trim(opt_str(positional(args, 1), ""));
  let flag_dir = trim(flag_or(args, "dir", ""));
  let raw = match string_length(flag_dir) > 0 {
    True -> flag_dir,
    False -> match string_length(positional_dir) > 0 {
      True -> positional_dir,
      False -> match get_secret("CLARITY_HITL_DIR") {
        Some(v) -> v,
        None -> ".clarity-hitl"
      }
    }
  };
  normalize_dir(raw)
}

export effect[FileSystem, Secret, Log] function run_hitl_cancel(args: List<String>) -> Unit {
  let key = trim(opt_str(positional(args, 0), ""));
  match string_length(key) == 0 {
    True -> {
      print_string("Usage: clarity-agent cancel <key> [dir] [--dir <path>]");
      exit(1)
    },
    False -> {
      let dir = resolve_dir(args);
      make_dir(dir);
      let safe_key = to_safe_key(key);
      let question_path = path_join(dir, safe_key ++ ".question");
      match file_exists(question_path) {
        True -> {
          remove_file(question_path);
          print_string("Cancelled: " ++ key)
        },
        False -> print_string("No question found: " ++ key)
      }
    }
  }
}
