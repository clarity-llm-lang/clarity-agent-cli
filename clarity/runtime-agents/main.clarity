module RuntimeAgents

import { positional, flag_or } from "std/cli"
import { get, get_or, get_nested, arr_get, arr_len } from "std/json"

function noop_rtagents() -> Unit {}

function opt_str(value: Option<String>, fallback: String) -> String {
  match value {
    Some(v) -> v,
    None -> fallback
  }
}

function strip_trailing_slash(url: String) -> String {
  let trimmed = trim(url);
  match string_length(trimmed) == 0 {
    True -> trimmed,
    False -> match string_ends_with(trimmed, "/") {
      True -> strip_trailing_slash(substring(trimmed, 0, string_length(trimmed) - 1)),
      False -> trimmed
    }
  }
}

function normalize_runtime_url(raw: String) -> String {
  let trimmed = strip_trailing_slash(raw);
  match string_starts_with(trimmed, "http://") {
    True -> trimmed,
    False -> match string_starts_with(trimmed, "https://") {
      True -> trimmed,
      False -> "http://" ++ trimmed
    }
  }
}

function auth_headers(token: String) -> String {
  let t = trim(token);
  match string_length(t) == 0 {
    True -> "{}",
    False -> "{\"Authorization\":\"Bearer " ++ json_escape_string(t) ++ "\"}"
  }
}

function is_http_success(status: Int64) -> Bool {
  status >= 200 and status <= 299
}

effect[Network] function request_full_checked(
  method: String,
  url: String,
  headers_json: String,
  body: String
) -> Result<String, String> {
  match http_request_full(method, url, headers_json, body) {
    Err(msg) -> Err(msg),
    Ok(payload) -> {
      let status_text = get_or(payload, "status", "0");
      let response_body = get_or(payload, "body", "");
      match string_to_int(status_text) {
        None -> Err(method ++ " " ++ url ++ " returned malformed status"),
        Some(status) -> match is_http_success(status) {
          True -> Ok(response_body),
          False -> Err(method ++ " " ++ url ++ " failed (" ++ status_text ++ "): " ++ response_body)
        }
      }
    }
  }
}

effect[FileSystem, Log] function prompt_required(prompt: String) -> String {
  print_string(prompt);
  let value = trim(read_line());
  match string_length(value) > 0 {
    True -> value,
    False -> {
      print_string("Value is required.");
      prompt_required(prompt)
    }
  }
}

effect[Log] function print_rows(items_json: String, idx: Int64) -> Unit {
  let count = arr_len(items_json);
  match idx >= count {
    True -> noop_rtagents(),
    False -> {
      match arr_get(items_json, idx) {
        None -> print_string("  " ++ int_to_string(idx + 1) ++ ". <invalid entry>"),
        Some(item_json) -> {
          let service_id = get_or(item_json, "serviceId", "unknown-service");
          let display = get_or(item_json, "displayName", service_id);
          let agent_id = opt_str(get_nested(item_json, "agent.agentId"), "-");
          let name = opt_str(get_nested(item_json, "agent.name"), display);
          let triggers = opt_str(get_nested(item_json, "agent.triggers"), "[]");
          let lifecycle = get_or(item_json, "lifecycle", "unknown");
          let health = get_or(item_json, "health", "unknown");
          print_string(
            "  "
              ++ int_to_string(idx + 1)
              ++ ". "
              ++ name
              ++ " ("
              ++ agent_id
              ++ ") service="
              ++ service_id
              ++ " triggers="
              ++ triggers
              ++ " lifecycle="
              ++ lifecycle
              ++ " health="
              ++ health
          )
        }
      };
      print_rows(items_json, idx + 1)
    }
  }
}

export effect[Network, FileSystem, Log] function run_runtime_agents(args: List<String>) -> Unit {
  let runtime_arg = opt_str(positional(args, 0), "");
  let runtime_raw = match string_length(trim(runtime_arg)) > 0 {
    True -> runtime_arg,
    False -> prompt_required("runtime url> ")
  };
  let runtime_url = normalize_runtime_url(runtime_raw);
  let token = trim(flag_or(args, "token", ""));
  let url = runtime_url ++ "/api/agents/registry";

  match request_full_checked("GET", url, auth_headers(token), "") {
    Err(msg) -> {
      print_string("Failed to load runtime registry: " ++ msg);
      exit(1)
    },
    Ok(body) -> {
      let items_json = get_or(body, "items", "[]");
      let count = arr_len(items_json);
      print_string("Runtime: " ++ runtime_url);
      match count <= 0 {
        True -> print_string("No registered agent services found."),
        False -> print_rows(items_json, 0)
      }
    }
  }
}

effect[Network, FileSystem, Log] function main() -> Unit {
  run_runtime_agents(get_args())
}
