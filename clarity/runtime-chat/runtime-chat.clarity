module RuntimeChat

import { flag_or, flag_int_or, positional, has_flag } from "std/cli"
import { get, get_or, get_nested, arr_get, arr_len } from "std/json"
import { poll, MuxEvent } from "std/mux"
import { connect_headers, close } from "std/sse"
import {
  opt_str,
  parse_int_or,
  clamp,
  max_i64,
  bool_not,
  normalize_runtime_url,
  auth_headers,
  json_headers,
  request_full_checked,
  registry_url,
  run_summaries_url,
  run_events_url,
  run_events_stream_url,
  run_messages_url,
  agents_events_url,
  run_created_payload,
  run_started_payload,
  user_message_payload,
  event_items_json,
  event_message,
  is_terminal_kind
} from "../runtime-shared/runtime-shared"

type SelectedAgent = {
  serviceId: String,
  agentId: String,
  name: String
}

type PollState = {
  nextSeq: Int64,
  sawOutput: Bool,
  terminal: Bool
}

type ChatContext = {
  runtimeUrl: String,
  token: String,
  serviceId: String,
  agent: String,
  runId: String,
  pollMs: Int64,
  eventsLimit: Int64,
  useStream: Bool
}

function noop_rtchat() -> Unit {}

function is_operator_input_kind(kind: String) -> Bool {
  kind == "agent.hitl_input" or kind == "agent.human_message" or kind == "agent.chat.user_message"
}

function parse_seq(event_json: String) -> Int64 {
  parse_int_or(opt_str(get(event_json, "seq"), "0"), 0)
}

function event_agent(event_json: String, default_agent: String) -> String {
  let a = opt_str(get_nested(event_json, "data.agent"), "");
  match string_length(a) > 0 {
    True -> a,
    False -> {
      let b = opt_str(get_nested(event_json, "data.agentId"), "");
      match string_length(b) > 0 {
        True -> b,
        False -> default_agent
      }
    }
  }
}

function extract_agent(item_json: String) -> SelectedAgent {
  let service_id = get_or(item_json, "serviceId", "unknown-service");
  let fallback_agent = get_or(item_json, "displayName", service_id);
  let agent_id = opt_str(get_nested(item_json, "agent.agentId"), fallback_agent);
  let name = opt_str(get_nested(item_json, "agent.name"), fallback_agent);
  {
    serviceId: service_id,
    agentId: agent_id,
    name: name
  }
}

function is_terminal_status(status: String) -> Bool {
  status == "completed" or status == "failed" or status == "cancelled"
}

function find_latest_active_run(
  items_json: String,
  idx: Int64,
  service_id: String,
  agent: String
) -> Option<String> {
  let count = arr_len(items_json);
  match idx >= count {
    True -> None,
    False -> match arr_get(items_json, idx) {
      None -> find_latest_active_run(items_json, idx + 1, service_id, agent),
      Some(item_json) -> {
        let run_id = trim(get_or(item_json, "runId", ""));
        let row_service_id = trim(get_or(item_json, "serviceId", ""));
        let row_agent = trim(get_or(item_json, "agent", ""));
        let status = trim(get_or(item_json, "status", ""));
        match string_length(run_id) > 0 and row_service_id == service_id and row_agent == agent and bool_not(is_terminal_status(status)) {
          True -> Some(run_id),
          False -> find_latest_active_run(items_json, idx + 1, service_id, agent)
        }
      }
    }
  }
}

effect[FileSystem, Log] function prompt_required(prompt: String) -> String {
  print_string(prompt);
  let value = trim(read_line());
  match string_length(value) > 0 {
    True -> value,
    False -> {
      print_string("Value is required.");
      prompt_required(prompt)
    }
  }
}

effect[Secret] function resolve_runtime_token(args: List<String>) -> String {
  let flag_token = trim(flag_or(args, "token", ""));
  match string_length(flag_token) > 0 {
    True -> flag_token,
    False -> match get_secret("CLARITY_RUNTIME_TOKEN") {
      Some(v) -> trim(v),
      None -> ""
    }
  }
}

effect[Network] function fetch_registry(base: String, token: String) -> Result<String, String> {
  request_full_checked("GET", registry_url(base), auth_headers(token), "")
}

effect[Network] function fetch_latest_active_run(
  base: String,
  token: String,
  service_id: String,
  agent: String
) -> Option<String> {
  match request_full_checked("GET", run_summaries_url(base, 200), auth_headers(token), "") {
    Err(_) -> None,
    Ok(body) -> find_latest_active_run(get_or(body, "items", "[]"), 0, service_id, agent)
  }
}

effect[Network] function bootstrap_run(ctx: ChatContext) -> Result<String, String> {
  match request_full_checked(
    "POST",
    agents_events_url(ctx.runtimeUrl),
    json_headers(ctx.token),
    run_created_payload(ctx.serviceId, ctx.agent, ctx.runId, "api", "clarity-agent-cli")
  ) {
    Err(msg) -> Err(msg),
    Ok(_) -> request_full_checked(
      "POST",
      agents_events_url(ctx.runtimeUrl),
      json_headers(ctx.token),
      run_started_payload(ctx.serviceId, ctx.agent, ctx.runId, "api", "clarity-agent-cli")
    )
  }
}

effect[Network] function send_user_message(ctx: ChatContext, message: String) -> Result<String, String> {
  request_full_checked(
    "POST",
    run_messages_url(ctx.runtimeUrl, ctx.runId),
    json_headers(ctx.token),
    user_message_payload(ctx.serviceId, ctx.agent, message)
  )
}

effect[Log] function print_agent_rows(items_json: String, idx: Int64) -> Unit {
  let count = arr_len(items_json);
  match idx >= count {
    True -> noop_rtchat(),
    False -> {
      match arr_get(items_json, idx) {
        None -> print_string("  " ++ int_to_string(idx + 1) ++ ". <invalid entry>"),
        Some(item_json) -> {
          let selected = extract_agent(item_json);
          print_string("  " ++ int_to_string(idx + 1) ++ ". " ++ selected.name ++ " (" ++ selected.agentId ++ ") service=" ++ selected.serviceId)
        }
      };
      print_agent_rows(items_json, idx + 1)
    }
  }
}

function find_agent_by_service(items_json: String, idx: Int64, service_id: String) -> Option<SelectedAgent> {
  let count = arr_len(items_json);
  match idx >= count {
    True -> None,
    False -> match arr_get(items_json, idx) {
      None -> find_agent_by_service(items_json, idx + 1, service_id),
      Some(item_json) -> {
        let selected = extract_agent(item_json);
        match selected.serviceId == service_id {
          True -> Some(selected),
          False -> find_agent_by_service(items_json, idx + 1, service_id)
        }
      }
    }
  }
}

effect[FileSystem, Log] function select_agent_interactive(items_json: String, count: Int64) -> SelectedAgent {
  let raw = prompt_required("agent number> ");
  match string_to_int(raw) {
    None -> {
      print_string("Invalid selection. Enter 1-" ++ int_to_string(count) ++ ".");
      select_agent_interactive(items_json, count)
    },
    Some(n) -> {
      let valid = n >= 1 and n <= count;
      match valid {
        False -> {
          print_string("Invalid selection. Enter 1-" ++ int_to_string(count) ++ ".");
          select_agent_interactive(items_json, count)
        },
        True -> match arr_get(items_json, n - 1) {
          Some(item_json) -> extract_agent(item_json),
          None -> {
            print_string("Selection not available. Try again.");
            select_agent_interactive(items_json, count)
          }
        }
      }
    }
  }
}

effect[FileSystem, Log] function resolve_selected_agent(
  items_json: String,
  count: Int64,
  service_arg: String
) -> Result<SelectedAgent, String> {
  let trimmed = trim(service_arg);
  match string_length(trimmed) == 0 {
    True -> Ok(select_agent_interactive(items_json, count)),
    False -> {
      let maybe_index = parse_int_or(trimmed, 0);
      let by_index = maybe_index >= 1 and maybe_index <= count;
      match by_index {
        True -> match arr_get(items_json, maybe_index - 1) {
          Some(item_json) -> Ok(extract_agent(item_json)),
          None -> Err("service selection index is not available: " ++ trimmed)
        },
        False -> match find_agent_by_service(items_json, 0, trimmed) {
          Some(selected) -> Ok(selected),
          None -> Err("service not found in runtime registry: " ++ trimmed)
        }
      }
    }
  }
}

effect[Log] function render_event(event_json: String, default_agent: String) -> Unit {
  let kind = get_or(event_json, "kind", "event");
  let message = event_message(event_json);
  let agent = event_agent(event_json, default_agent);
  match kind == "agent.chat.user_message" {
    True -> print_string("you: " ++ message),
    False -> match kind == "agent.chat.assistant_message" {
      True -> print_string(agent ++ ": " ++ message),
      False -> print_string(agent ++ " (" ++ kind ++ "): " ++ message)
    }
  }
}

effect[Log] function apply_event(event_json: String, last_seq: Int64, default_agent: String) -> PollState {
  let seq = parse_seq(event_json);
  let is_new = seq > last_seq;
  match is_new {
    True -> render_event(event_json, default_agent),
    False -> noop_rtchat()
  };
  let kind = get_or(event_json, "kind", "event");
  {
    nextSeq: max_i64(last_seq, seq),
    sawOutput: is_new and bool_not(is_operator_input_kind(kind)),
    terminal: is_new and is_terminal_kind(kind)
  }
}

function merge_state(a: PollState, b: PollState) -> PollState {
  {
    nextSeq: max_i64(a.nextSeq, b.nextSeq),
    sawOutput: a.sawOutput or b.sawOutput,
    terminal: a.terminal or b.terminal
  }
}

effect[Log] function scan_events(items_json: String, idx: Int64, state: PollState, default_agent: String) -> PollState {
  let count = arr_len(items_json);
  match idx >= count {
    True -> state,
    False -> {
      let next = match arr_get(items_json, idx) {
        None -> state,
        Some(event_json) -> {
          let one = apply_event(event_json, state.nextSeq, default_agent);
          merge_state(state, one)
        }
      };
      scan_events(items_json, idx + 1, next, default_agent)
    }
  }
}

effect[Network, Log] function flush_events(ctx: ChatContext, last_seq: Int64) -> PollState {
  match request_full_checked(
    "GET",
    run_events_url(ctx.runtimeUrl, ctx.runId, ctx.eventsLimit),
    auth_headers(ctx.token),
    ""
  ) {
    Err(msg) -> {
      print_string("event poll error: " ++ msg);
      {
        nextSeq: last_seq,
        sawOutput: False,
        terminal: False
      }
    },
    Ok(body) -> {
      let items_json = event_items_json(body);
      scan_events(
        items_json,
        0,
        {
          nextSeq: last_seq,
          sawOutput: False,
          terminal: False
        },
        ctx.agent
      )
    }
  }
}

effect[Network, Log, Time] function poll_after_send(ctx: ChatContext, attempt: Int64, state: PollState) -> PollState {
  match attempt >= 6 {
    True -> state,
    False -> {
      match attempt > 0 {
        True -> sleep(ctx.pollMs),
        False -> noop_rtchat()
      };
      let latest = flush_events(ctx, state.nextSeq);
      let merged = merge_state(state, latest);
      match merged.terminal {
        True -> merged,
        False -> match merged.sawOutput {
          True -> merged,
          False -> poll_after_send(ctx, attempt + 1, merged)
        }
      }
    }
  }
}

effect[Network, FileSystem, Log, Time] function run_poll_loop(ctx: ChatContext, last_seq: Int64) -> Unit {
  let latest = flush_events(ctx, last_seq);
  match latest.terminal {
    True -> print_string("Run is terminal. Exiting chat."),
    False -> {
      print_string("you>");
      let input = trim(read_line());
      match string_length(input) == 0 {
        True -> run_poll_loop(ctx, latest.nextSeq),
        False -> match input == "/exit" or input == "/quit" {
          True -> print_string("Closing runtime chat."),
          False -> match input == "/refresh" {
            True -> run_poll_loop(ctx, latest.nextSeq),
            False -> match input == "/status" {
              True -> {
                print_string("Run: " ++ ctx.runId ++ " service=" ++ ctx.serviceId ++ " agent=" ++ ctx.agent);
                run_poll_loop(ctx, latest.nextSeq)
              },
              False -> {
                match send_user_message(ctx, input) {
                  Err(msg) -> print_string("send error: " ++ msg),
                  Ok(_) -> noop_rtchat()
                };
                let after_send = poll_after_send(
                  ctx,
                  0,
                  {
                    nextSeq: latest.nextSeq,
                    sawOutput: False,
                    terminal: False
                  }
                );
                match after_send.sawOutput {
                  True -> noop_rtchat(),
                  False -> print_string("No agent response events yet. Ensure an active runtime agent loop is consuming run messages.")
                };
                match after_send.terminal {
                  True -> print_string("Run is terminal. Exiting chat."),
                  False -> run_poll_loop(ctx, after_send.nextSeq)
                }
              }
            }
          }
        }
      }
    }
  }
}

effect[Network, FileSystem, Log, Time] function run_stream_loop(ctx: ChatContext, handle: Int64, last_seq: Int64) -> Unit {
  match poll(handle, ctx.pollMs) {
    SseEvent(data) -> {
      let one = apply_event(data, last_seq, ctx.agent);
      match one.terminal {
        True -> {
          close(handle);
          print_string("Run is terminal. Exiting chat.")
        },
        False -> run_stream_loop(ctx, handle, one.nextSeq)
      }
    },
    StdinLine(line) -> {
      let input = trim(line);
      match string_length(input) == 0 {
        True -> run_stream_loop(ctx, handle, last_seq),
        False -> match input == "/exit" or input == "/quit" {
          True -> {
            close(handle);
            print_string("Closing runtime chat.")
          },
          False -> match input == "/refresh" {
            True -> {
              let refreshed = flush_events(ctx, last_seq);
              match refreshed.terminal {
                True -> {
                  close(handle);
                  print_string("Run is terminal. Exiting chat.")
                },
                False -> run_stream_loop(ctx, handle, refreshed.nextSeq)
              }
            },
            False -> match input == "/status" {
              True -> {
                print_string("Run: " ++ ctx.runId ++ " service=" ++ ctx.serviceId ++ " agent=" ++ ctx.agent);
                run_stream_loop(ctx, handle, last_seq)
              },
              False -> {
                match send_user_message(ctx, input) {
                  Err(msg) -> print_string("send error: " ++ msg),
                  Ok(_) -> noop_rtchat()
                };
                run_stream_loop(ctx, handle, last_seq)
              }
            }
          }
        }
      }
    },
    SseEnded -> {
      close(handle);
      print_string("Runtime event stream ended. Exiting chat.")
    },
    StdinEof -> {
      close(handle);
      print_string("stdin closed. Exiting chat.")
    },
    Timeout -> run_stream_loop(ctx, handle, last_seq)
  }
}

effect[Network, FileSystem, Log, Time] function start_chat(ctx: ChatContext, last_seq: Int64) -> Unit {
  match ctx.useStream {
    False -> run_poll_loop(ctx, last_seq),
    True -> {
      let url = run_events_stream_url(ctx.runtimeUrl, ctx.runId, ctx.eventsLimit);
      match connect_headers(url, auth_headers(ctx.token)) {
        Err(msg) -> {
          print_string("run stream unavailable: " ++ msg ++ ". Falling back to polling.");
          run_poll_loop(ctx, last_seq)
        },
        Ok(handle) -> run_stream_loop(ctx, handle, last_seq)
      }
    }
  }
}

export effect[Network, FileSystem, Secret, Log, Time] function run_runtime_chat(args: List<String>) -> Unit {

  let runtime_arg = opt_str(positional(args, 0), "");
  let service_arg = opt_str(positional(args, 1), "");

  let runtime_input = match string_length(trim(runtime_arg)) > 0 {
    True -> runtime_arg,
    False -> prompt_required("runtime url> ")
  };

  let runtime_url = normalize_runtime_url(runtime_input);

  let token = resolve_runtime_token(args);

  let poll_ms = clamp(100, 5000, flag_int_or(args, "poll-ms", 1200));
  let events_limit = clamp(1, 5000, flag_int_or(args, "events-limit", 200));
  let use_stream = bool_not(has_flag(args, "no-stream"));

  let run_id_flag = trim(flag_or(args, "run-id", ""));
  let agent_override = trim(flag_or(args, "agent", ""));
  let resume_latest = has_flag(args, "resume-latest");

  match fetch_registry(runtime_url, token) {
    Err(msg) -> {
      print_string("Failed to load runtime registry: " ++ msg);
      exit(1)
    },
    Ok(registry_body) -> {
      let items_json = get_or(registry_body, "items", "[]");
      let count = arr_len(items_json);
      match count <= 0 {
        True -> {
          print_string("No registered agents were returned by runtime.");
          exit(1)
        },
        False -> {
          print_string("Connected to runtime: " ++ runtime_url);
          print_string("Select an agent:");
          print_agent_rows(items_json, 0);

          match resolve_selected_agent(items_json, count, service_arg) {
            Err(msg) -> {
              print_string(msg);
              exit(1)
            },
            Ok(selected) -> {
              let agent = match string_length(agent_override) > 0 {
                True -> agent_override,
                False -> match string_length(selected.agentId) > 0 {
                  True -> selected.agentId,
                  False -> selected.name
                }
              };

              let resumed_run = match string_length(run_id_flag) == 0 and resume_latest {
                True -> fetch_latest_active_run(runtime_url, token, selected.serviceId, agent),
                False -> None
              };

              let run_id = match string_length(run_id_flag) > 0 {
                True -> run_id_flag,
                False -> match resumed_run {
                  Some(existing_run) -> existing_run,
                  None -> "run_cli_" ++ int_to_string(timestamp_to_int(now()))
                }
              };

              let resumed = match resumed_run {
                Some(_) -> True,
                None -> False
              };
              let attached = string_length(run_id_flag) > 0 or resumed;
              let ctx = {
                runtimeUrl: runtime_url,
                token: token,
                serviceId: selected.serviceId,
                agent: agent,
                runId: run_id,
                pollMs: poll_ms,
                eventsLimit: events_limit,
                useStream: use_stream
              };

              match attached {
                True -> match resumed {
                  True -> print_string("Resumed run: " ++ run_id),
                  False -> print_string("Attached to run: " ++ run_id)
                },
                False -> match bootstrap_run(ctx) {
                  Err(msg) -> {
                    print_string("Failed to bootstrap run: " ++ msg);
                    exit(1)
                  },
                  Ok(_) -> print_string("Started run: " ++ run_id)
                }
              };

              print_string("Runtime: " ++ runtime_url);
              print_string("Service: " ++ selected.serviceId);
              print_string("Agent: " ++ agent);
              print_string("Commands: /status, /refresh, /exit");

              let initial = flush_events(ctx, 0);
              match initial.terminal {
                True -> print_string("Run is terminal. Exiting chat."),
                False -> start_chat(ctx, initial.nextSeq)
              }
            }
          }
        }
      }
    }
  }
}
