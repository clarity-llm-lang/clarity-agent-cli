{
  "name": "clarity-agent-cli",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "CLI and broker interface for Human-in-the-Loop workflows across Clarity agents",
  "license": "MIT",
  "scripts": {
    "build": "npm run build:cli",
    "build:cli": "rm -rf dist && mkdir -p dist && clarityc pack clarity/main.clarity -f main -o dist/clarity-agent.cjs && clarityc pack clarity/claritycli.clarity -f main -o dist/claritycli.cjs && chmod +x dist/clarity-agent.cjs dist/claritycli.cjs",
    "bundle": "npm run build && npm pack",
    "install:bin": "npm run build && bash scripts/install-user-bin.sh",
    "dev": "clarityc run clarity/main.clarity -f main",
    "start": "node dist/clarity-agent.cjs",
    "lint:clarity": "bash scripts/check-pure-clarity.sh",
    "lint": "npm run lint:clarity",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:coverage": "npm run test"
  },
  "bin": {
    "clarity-agent": "dist/clarity-agent.cjs",
    "clarity-hitl": "dist/clarity-agent.cjs",
    "claritycli": "dist/claritycli.cjs"
  },
  "dependencies": {
    "clarity-lang": "https://codeload.github.com/clarity-llm-lang/clarity-compiler/tar.gz/main"
  },
  "devDependencies": {
    "prettier": "^3.5.3"
  }
}
